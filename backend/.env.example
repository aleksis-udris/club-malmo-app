# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES=15m
DEVICE_PROVISIONING_KEY=dev-tv-provisioning-key

# ─── Database (SQLite, file-backed) ───────────────────────
DATABASE_FILE=data/squash.sqlite

# ─── Redis (optional; in-memory fallback if unset) ────────
# REDIS_URL=redis://localhost:6379

# ─── Sportradar (Squash API v2) ───────────────────────────
# >>> PUT YOUR SPORTRADAR API TOKEN HERE <<<
SPORTRADAR_API_KEY=
# v2 base URL. {access_level}=trial|production
SPORTRADAR_BASE_URL=https://api.sportradar.com/squash/trial/v2/en
# Master switch — sync runs only when true AND a key is present.
SPORTRADAR_ENABLED=true
# Requests/second budget (token bucket) — match your plan QPS.
SPORTRADAR_QPS=1
# API budget: max origin requests/day, confined to club working hours (24h clock).
SPORTRADAR_DAILY_LIMIT=1000
SPORTRADAR_WORK_START_HOUR=9
SPORTRADAR_WORK_END_HOUR=17
