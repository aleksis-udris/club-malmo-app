# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Auth ─────────────────────────────────────────────────
# Use a long random value in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES=15m
# Provisioning key TVs present at enrolment
DEVICE_PROVISIONING_KEY=dev-tv-provisioning-key

# ─── Database ─────────────────────────────────────────────
# If DATABASE_URL is set, Postgres is used. Otherwise an in-memory
# SQLite database is used (great for local dev / demos).
# DATABASE_URL=postgres://user:pass@localhost:5432/squash

# ─── Redis (optional) ─────────────────────────────────────
# If unset, an in-memory cache + rate-limiter is used instead.
# REDIS_URL=redis://localhost:6379

# ─── Sportradar ───────────────────────────────────────────
# >>> PUT YOUR SPORTRADAR API TOKEN HERE <<<
SPORTRADAR_API_KEY=
# Base URL for your plan (trial vs production differ). Example shown.
SPORTRADAR_BASE_URL=https://api.sportradar.com/squash/trial/v1/en
# Master switch: when false (or key missing) sync is skipped and cached/empty data is served.
SPORTRADAR_ENABLED=false
# Requests/second budget for the token bucket (match your plan QPS).
SPORTRADAR_QPS=1
